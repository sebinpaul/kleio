# ========= Global =========

# OS generated
.DS_Store
Thumbs.db

# IDE / editor
.vscode/
.idea/
.cursor/

# Secrets & local env (never commit)
*.env
*.env.*
!.env.example

# SQLite (Django internals only — app data lives in MongoDB)
*.sqlite3

# ========= Backend (Django in BE/) =========

# Byte-compiled / cache
BE/__pycache__/
BE/**/*.py[cod]

# Virtual environments
BE/venv/
BE/.venv/
BE/env/
BE/ENV/

# Django runtime artifacts
BE/*.log
BE/*.pot
BE/*.pyc
BE/media/
BE/staticfiles/
BE/static_root/
BE/static_cdn/
BE/*.mo

# Migrations (MongoEngine project — keep only __init__.py)
BE/**/migrations/*.py
!BE/**/migrations/__init__.py

# Testing / coverage
BE/htmlcov/
BE/.coverage
BE/.pytest_cache/
BE/.cache/
BE/test-results/

# Build / tooling
BE/.mypy_cache/
BE/*.manifest
BE/*.spec
BE/dist/
BE/build/
BE/*.egg-info/

# Pipenv / Poetry (project uses requirements.txt)
BE/Pipfile.lock
BE/poetry.lock

# Local overrides
BE/settings_local.py
BE/local_settings.py
BE/DEPLOYMENT.local.md

# Celery
BE/celerybeat-schedule
BE/celerybeat.pid

# Browser automation profile data
BE/chrome_data/

# ========= Frontend (Next.js in UI/) =========

UI/node_modules/
UI/.next/
UI/out/

# Logs
UI/npm-debug.log*
UI/yarn-debug.log*
UI/yarn-error.log*
UI/pnpm-debug.log*

# Tooling cache
UI/.eslintcache
UI/.turbo/
UI/.parcel-cache/
UI/.cache/
UI/tsconfig.tsbuildinfo
UI/*.tsbuildinfo

# Deployment platforms
UI/.vercel/
UI/.netlify/

# Clerk local config (can include secrets)
UI/.clerk/

# Testing
UI/coverage/
UI/junit.xml
